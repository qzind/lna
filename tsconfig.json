{
  "compilerOptions": {
    "target": "es2017",
    "module": "es2022",
    "lib": ["es2022", "dom"],
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
