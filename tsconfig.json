{
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": "./",
    "resolveJsonModule": true
  },
  "include": ["src"]
}
